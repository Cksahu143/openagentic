ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000

# Shared secret with the TS bridge — generate with: openssl rand -hex 32
# Must match PYTHON_SERVICE_TOKEN in the TS app's .env
BRIDGE_SHARED_SECRET=dev-only-change-me

# Reuses the same Lovable AI Gateway key the TS app uses, if you have one.
LOVABLE_API_KEY=
LOVABLE_GATEWAY_BASE_URL=https://ai.gateway.lovable.dev/v1

# Or set a direct provider key instead:
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

DEFAULT_MODEL=google/gemini-3-flash-preview

CHROMA_PERSIST_DIR=./data/chroma

WORKSPACE_ROOT=./data/workspaces
WORKSPACE_MAX_FILE_BYTES=5000000

PLAYWRIGHT_ENABLED=true
PLAYWRIGHT_NAVIGATION_TIMEOUT_MS=15000

ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# OpenRouter (OpenAI-compatible) — used if set, takes priority over Google
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
