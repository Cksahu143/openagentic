{
  "manifest_version": 3,
  "name": "OpenAgent Phase 1",
  "version": "0.1.0",
  "description": "OpenAgent Phase 1 — PRPAVL loop with Perception, Action, Verification, Intelligence, Orchestrator, Recovery, and Guardrail engines. Ships a live Workspace side panel and an AI cursor.",
  "permissions": ["activeTab", "scripting", "storage", "sidePanel"],
  "background": { "service_worker": "background/service-worker.js", "type": "module" },
  "action": { "default_title": "Open OpenAgent Workspace" },
  "side_panel": { "default_path": "sidepanel/index.html" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": { "48": "icon.png", "128": "icon.png" },
  "web_accessible_resources": [
    { "resources": ["content/cursor.css"], "matches": ["<all_urls>"] }
  ]
}
