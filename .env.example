# Existing Supabase vars are already in your real .env — see that file.
# This example only documents variables ADDED for the Python service bridge.

# Base URL of the running python-service (see python-service/README.md)
PYTHON_SERVICE_URL=http://localhost:8000

# Must match BRIDGE_SHARED_SECRET in python-service/.env
# Generate with: openssl rand -hex 32
PYTHON_SERVICE_TOKEN=
